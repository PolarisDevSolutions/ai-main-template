# =============================================================================
# CMS Core Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# -----------------------------------------------------------------------------
# Get these from your Supabase project: Settings > API

# Public Supabase URL (safe for client-side)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key (safe for client-side, used for auth)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (server-side only, KEEP SECRET)
# Used for SSG generation and server-side operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ⚠️  VITE_ prefixed variables are exposed to the browser.
#     NEVER put secrets (like SUPABASE_SERVICE_ROLE_KEY) in VITE_ variables.

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
# Your production domain (used for canonical URLs, sitemap, Open Graph)
SITE_URL=https://your-domain.com

# Alias for Vite (client-side access)
VITE_SITE_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Restricts CORS on all Netlify functions to this origin only.
# ⚠️  Set this in Netlify Site Settings > Environment variables for production.
# Without this, functions fall back to ALLOWED_ORIGIN=* (permissive).
# Example: https://yourfirm.com (no trailing slash)
ALLOWED_ORIGIN=https://your-domain.com

# -----------------------------------------------------------------------------
# Netlify Configuration (Optional)
# -----------------------------------------------------------------------------
# Build hook URL for triggering deployments from the CMS
# Create at: Netlify Dashboard > Site Settings > Build & deploy > Build hooks
NETLIFY_BUILD_HOOK_URL=https://api.netlify.com/build_hooks/your-hook-id

# QA Scanner base URL (frontend - optional, used for scan target)
# Defaults to http://localhost:8080 if not set
VITE_QA_BASE_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# GitHub QA Scanner Configuration (Server-Side Only)
# ⚠️  These variables are NEVER exposed to the frontend
# ⚠️  Set these in Netlify Site Settings > Build & deploy > Environment
# DO NOT use VITE_ prefix for these - they are server-side only
# =============================================================================
# Personal Access Token for GitHub Actions (server-side only)
# Required scopes: repo (for workflow dispatch and run access)
# Create at: GitHub Settings > Developer settings > Personal access tokens
GITHUB_QA_TOKEN=ghp_your-token-here

# GitHub repository (server-side only)
# Format: owner/repository
# Example: ConstellationMarketing/jupiter-design
GITHUB_REPOSITORY=owner/repository

# ⚠️  WHY NO FRONTEND TOKENS?
# - All GitHub API calls happen on the backend
# - Frontend never authenticates with GitHub directly
# - Tokens are kept secure in server environment only
# - Frontend calls backend endpoints (/.netlify/functions/qa-*) only

# For local development:
# Set GITHUB_QA_TOKEN and GITHUB_REPOSITORY in your .env file
# On Netlify: Set these in Site Settings > Build & deploy > Environment

# For production deployment checklist:
# [ ] Set GITHUB_QA_TOKEN in Netlify environment
# [ ] Set GITHUB_REPOSITORY in Netlify environment
# [ ] Verify token has 'repo' scope and workflow permissions
# [ ] Test QA scan trigger from admin dashboard

# Backend endpoints available to frontend (no token needed):
# - GET  /.netlify/functions/qa-get-latest-run
# - GET  /.netlify/functions/qa-run-status?runId=123
# - POST /.netlify/functions/trigger-qa (requires admin auth)

# =============================================================================
# Development
# =============================================================================
# For local development, you can use:
# VITE_SITE_URL=http://localhost:8080
# SITE_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Legacy / Unused (do NOT set unless you know you need them)
# -----------------------------------------------------------------------------
# ADMIN_PASSWORD — Referenced by vendor/cms-core/netlify/functions/_shared.cjs
# (legacy requireAdmin helper). No active function currently uses it.
# Do NOT set unless you write a custom function that calls requireAdmin().
